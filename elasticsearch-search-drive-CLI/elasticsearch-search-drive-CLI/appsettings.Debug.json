{
  "debugMode": {
    "enabled": true,
    "verboseLogging": true,
    "captureRawResponses": true,
    "captureRequestQueriesAndBodies": true,
    "disableDirectStreaming": true
  },
  "elasticsearch": {
    "url": "http://localhost:9200",
    "indexName": "disk-items-debug",
    "timeout": 60,
    "retryAttempts": 5,
    "enableDebug": true,
    "prettyJson": true
  },
  "indexing": {
    "batchSize": 10,
    "defaultPageSize": 5,
    "enableValidation": true,
    "skipInvalidItems": false,
    "logDetails": true,
    "logItemsDetails": true
  },
  "search": {
    "defaultPageSize": 5,
    "maxPageSize": 50,
    "highlightResults": true,
    "enableAggregations": true,
    "logSearchQueries": true
  },
  "logging": {
    "logLevel": "Debug",
    "enableConsoleLogging": true,
    "enableFileLogging": true,
    "logDirectory": "./logs/debug",
    "logFileName": "elasticsearch-search-drive-debug-{date}.log",
    "includeTimestamps": true,
    "includeStackTraces": true
  },
  "testDirs": {
    "testIndexPaths": [
      "C:\\Users\\Documents",
      "C:\\Users\\Downloads",
      "C:\\Windows\\System32"
    ],
    "excludePatterns": [
      "node_modules",
      ".git",
      "bin",
      "obj",
      ".vs",
      "packages",
      "AppData"
    ],
    "excludeFileExtensions": [
      ".tmp",
      ".temp",
      ".lock",
      ".log"
    ]
  },
  "performance": {
    "enableAsync": true,
    "maxConcurrentIndexing": 2,
    "enableBatching": true,
    "batchFlushIntervalMs": 500,
    "measurePerformance": true
  },
  "testScenarios": {
    "indexing": {
      "testDirectories": [
        "C:\\Users\\Documents"
      ],
      "recursive": true,
      "expectMinItems": 10
    },
    "search": {
      "searchTerms": [
        "document",
        "pdf",
        "xlsx"
      ],
      "searchExtensions": [
        ".pdf",
        ".txt",
        ".xlsx"
      ],
      "expectResults": true
    }
  }
}
